{
  "version": 2,
  "builds": [
    {
      "src": "src/api/github.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/vite"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/api/github.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
